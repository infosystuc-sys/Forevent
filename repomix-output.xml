                                                    gatesTable.getRowModel().rows.map((row) => (
                                                        <TableRow
                                                            className={`w-full ${row.getIsSelected() ? "bg-zinc-800" : ""}`}
                                                            key={row.id}
                                                            data-state={row.getIsSelected() && "selected"}
                                                            onClick={() => {
                                                                const selected = !row.getIsSelected()
