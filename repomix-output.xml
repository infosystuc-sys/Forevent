                                                        </TableCell>
                                                    </TableRow>
                                                )}
                                            </TableBody>
                                        </Table>
                                    </CardContent>
                                </Card>
                                <div className='px-5'>
                                    <DataTablePagination table={countersTable} />
                                </div>
                            </div>
