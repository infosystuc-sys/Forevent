                                </div>
                            </div>
                            <div className='flex space-x-5'>
                                <div className='flex flex-1 justify-center items-center w-full'>
                                    <div className={`w-full space-y-5`}>
                                        <Card className="bg-background">
                                            <CardContent className='space-y-5 p-0 w-full'>
