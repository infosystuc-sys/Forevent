import type { DefaultSession } from "next-auth";
import NextAuth from "next-auth";
import CredentialsProvider from "next-auth/providers/credentials";
import * as argon2 from "argon2";
import prisma from "@forevent/db";
export type { Session } from "next-auth";

declare module "next-auth" {
  interface Session {
    user: {
      id: string;
      createdAt: Date,
      emailVerified: boolean,
      passwordVerified: boolean
    } & DefaultSession["user"];
  }
}

export const {
  handlers: { GET, POST },
  auth,
  signIn,
  signOut,
} = NextAuth({
  // adapter: PrismaAdapter(prisma),
  providers: [
    CredentialsProvider({
      name: "credentials",
      type: "credentials",
      credentials: {
        email: { label: "Email", type: "email", placeholder: "example@example.com", },
        password: { label: "Password", type: "password" },
        internal: { label: "Internal", type: "checkbox", hidden: true }
      },
      async authorize({ email, password, internal }, request) {
        console.log(email + " " + password, "CREDENCIALES", internal, "internal?")

        if (internal === true || internal === "true") {
          console.log("internal")
          const internalUser = await prisma.internalUser.findUnique({
            where: { email: email as string, discharged: true },
            select: {
              id: true,
              createdAt: true,
              name: true,
              image: true,
              email: true,
              emailVerified: true,
              password: true,
              passwordVerified: true,
            }
          })

          console.log(internalUser, "user")

          if (!internalUser) {
            console.log("user not found")
            return null
          }

          console.log("user found")

          const isPasswordCorrect = await argon2.verify(internalUser.password as string, password as string);

          if (!isPasswordCorrect) {
            console.log("password is not correct")
            return null
          }

          console.log("password is correct")

          return { id: internalUser.id, createdAt: internalUser.createdAt, name: internalUser.name, image: internalUser.image, email: internalUser.email, emailVerified: internalUser.emailVerified, passwordVerified: internalUser.passwordVerified }

        } else {
          console.log("external")
          const user = await prisma.user.findUnique({
            where: { email: email as string, discharged: true },
            select: {
              id: true,
              createdAt: true,
              name: true,
              image: true,
              email: true,
              emailVerified: true,
              password: true,
              passwordVerified: true,
            }
          })

          console.log(user, "user")

          if (!user) {
            console.log("user not found")
            return null
          }

          console.log("user found")

          const isPasswordCorrect = await argon2.verify(user.password as string, password as string);

          if (!isPasswordCorrect) {
            console.log("password is not correct")
            return null
          }

          console.log("password is correct")

          return { id: user.id, createdAt: user.createdAt, name: user.name, image: user.image, email: user.email, emailVerified: user.emailVerified, passwordVerified: user.passwordVerified }

        }
