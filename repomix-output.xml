                                </NavigationMenuList>
                                :
                                <NavigationMenuList>
                                    <NavigationMenuItem>
                                        <Link href={`/v1/${params?.guildId}`} legacyBehavior passHref>
                                            <NavigationMenuLink className={navigationMenuTriggerStyle()}>
                                                Inicio
                                            </NavigationMenuLink>
                                        </Link>
                                    </NavigationMenuItem>
