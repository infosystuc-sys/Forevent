                                </View>
                                <View style={{ gap: 5 }}>
                                    <Text style={{ fontSize: 17.5, letterSpacing: 0, color: colors.text, textAlign: 'left' }}>
                                        {item.guild.name}
                                    </Text>
                                    <Text style={{ color: 'yellow', fontSize: 13 }}>
                                        Tu rol: {item.role === 'EMPLOYEE' ? "Cajero/Portero" : item.role === 'MANAGER' ? 'Gerencia' : "Propietario"}
