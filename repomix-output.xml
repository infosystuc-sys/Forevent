                                                                                    header.getContext()
                                                                                )}
                                                                        </TableHead>
                                                                    )
                                                                })}
                                                            </TableRow>
                                                        ))}
                                                    </TableHeader>
                                                    <TableBody className='w-full'>
                                                        {countersTable.getRowModel().rows?.length ? (
                                                            countersTable.getRowModel().rows.map((row) => (
                                                                <TableRow
                                                                    className={`w-full ${row.getIsSelected() ? "bg-zinc-800" : ""}`}
                                                                    key={row.id}
                                                                    data-state={row.getIsSelected() && "selected"}
                                                                    onClick={() => {
