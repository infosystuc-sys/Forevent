    enter.mutate({ userId: user!.id, userTicketId: ticket.data?.url ?? '' })
  }

  useEffect(() => {
    // socket.connect();
    socket.emit('joinTransaction', { userId: user?.id, userTicketId: eventTicketId });
    // socket.on('connect', () => { });
