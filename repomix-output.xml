                                                                ? "opacity-100"
                                                                : "opacity-0"
                                                        )} />
                                                </CommandItem>
                                            ))}
                                        </CommandGroup>
                                    </CommandList>
                                    <CommandSeparator />
                                </Command>
                            </PopoverContent>
                        </Popover>
                    </div>
                }
                <div>
