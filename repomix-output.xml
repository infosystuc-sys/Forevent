                        color: string;
                        about: string;
                        navigate: {
                            pathname: string;
                            params: {
                                category: string;
                            };
                        }
                    }, index: number
                }) => <MenuItem data={USER_CATEGORIES} setSelected={setSelected} selected={selected} carouselRef={carouselRef} item={item} index={index} />}
                customAnimation={animationStyle}
            />
        </View >
    );
}

export default UserCategories
