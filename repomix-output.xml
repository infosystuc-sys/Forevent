                    return item
                }
            })
            purchaseForm.setValue("items", newItems)
        } else {
            console.log("NO pertecence al array", data, selectedItem, "item seleccionado")
            purchaseForm.setValue("items", [...purchaseForm.watch("items"), data])
        }
        itemForm.reset()
