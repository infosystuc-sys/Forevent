                    {(ticket.data?.quantity ?? 0) > 1 && <Text style={{ fontSize: 17.5, letterSpacing: 0, color: colors.text }} >
                      x{ticket.data?.quantity}
                    </Text>}
                  </View>
                </Pressable>
              </View>
            </View>
            <View style={{ paddingHorizontal: 15, marginTop: 1 }}>
