<file path="packages/db/prisma/schema.prisma">
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model Session {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  expiresAt      DateTime
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  internalUserId String?
  internalUser   InternalUser? @relation(fields: [internalUserId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([internalUserId])
}

model InternalUser {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  name             String    @db.Text
  email            String    @unique
  emailVerified    Boolean   @default(false)
  password         String    @db.Text
  passwordVerified Boolean   @default(false)
  image            String?   @db.Text
  discharged       Boolean   @default(true)
  sessions         Session[]
}

model User {
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now())
  name             String          @db.Text
  about            String?         @db.Text
  email            String          @unique
  emailVerified    Boolean         @default(false)
  password         String          @db.Text
  passwordVerified Boolean         @default(false)
  image            String?         @db.Text
  locale           String?         @db.Text
  zoneinfo         String?         @db.Text
  notifyAll        Boolean         @default(false)
  notifyEmails     Boolean         @default(false)
  notifyEvents     Boolean         @default(false)
  discharged       Boolean         @default(true)
  sessions         Session[]
  userOnGuilds     UserOnGuild[]
  ticketsBuyer     UserTicket[]    @relation("buyer")
  ticketsOwner     UserTicket[]    @relation("owner")
  giftsRequester   Gift[]          @relation("requester")
  giftsReceiver    Gift[]          @relation("receiver")
  friendsRequester Relationship[]  @relation("requester")
  friendsReceiver  Relationship[]  @relation("receiver")
  userOnEvents     UserOnEvent[]
  purchasesBuyer   UserPurchase[]  @relation("buyer")
  purchasesOwner   UserPurchase[]  @relation("owner")
  purchases        Purchase[]
  invites          Invite[]
  authChallenges   AuthChallenge[]
}

model AuthChallenge {
  id         String   @unique @default(uuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  code       String   @db.Text
  discharged Boolean  @default(true)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guildId    String?
  guild      Guild?   @relation(fields: [guildId], references: [id], onDelete: Cascade)

