                    }) => {
                      return (
                        <Pressable style={{ borderRadius: 5, backgroundColor: colors.primary, padding: 12.5, alignItems: 'center', justifyContent: 'center', flex: 1 }} onPress={() => {
                          onChange([...value, addForm.watch()]),
