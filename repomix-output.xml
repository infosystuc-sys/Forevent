                    </Avatar>
                </div>
            )
        },
    },
    {
        id: "name",
        accessorKey: "name",
        header: "Nombre",
        cell: ({ row }) => {
            return (
                <p>{row.original.name}</p>
            )
        }
    },
    {
        accessorKey: "price",
        header: "Precio",
        cell: ({ row }) => {
            return (
                <p>${row.original.price?.toLocaleString()}</p>
            )
        }
    },
    {
        accessorKey: "about",
        header: "Descripción",
        cell: ({ row }) => {
            return (
                <p>{row.original.about}</p>
            )
        }
    },
    {
        accessorKey: "type",
        header: "Tipo",
        cell: ({ row }) => {
            return (
