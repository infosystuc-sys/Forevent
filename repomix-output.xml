                    console.log("enviar entrada")
                    setSend(true)
                    handleExpandPress()
                  }}>
                    <MaterialCommunityIcons name={'ticket-confirmation-outline'} size={20} color={colors.text} />
                    <View>
                      <Text style={{ fontSize: 12.5, letterSpacing: 0, color: colors.text }} >
                        Enviar entrada a un amigo
                      </Text>
                    </View>
                  </Pressable>
                  <View style={{ flexDirection: 'row', padding: 10, gap: 20, alignItems: "center", paddingHorizontal: 5, borderBottomWidth: 1, borderBottomColor: "#444" }}>
                    <MaterialCommunityIcons name={'ticket-account'} size={20} color={colors.text} />
                    <View style={{ gap: 2.5 }}>
                      <Text style={{ fontSize: 12.5, letterSpacing: 0, color: colors.text }} >
                        Enviar entrada a un amigo
                      </Text>
                      <Text style={{ fontSize: 12.5, letterSpacing: 0, color: colors.text }} >
                        Cierra el {dayjs(ticket.data?.eventTicket?.event.startsAt).locale('es').format('DD')} de {dayjs(ticket.data?.eventTicket?.event.startsAt).locale('es').subtract(2, 'hour').format('MMMM').charAt(0).toUpperCase()}{dayjs(ticket.data?.eventTicket?.event.startsAt).locale('es').subtract(2, 'hour').format('MMMM').slice(1)}, {ticket.data?.eventTicket?.event.startsAt ? dayjs(ticket.data?.eventTicket?.event.startsAt).locale('es').subtract(2, 'hour').format('LT') : "00:00"}
                      </Text>
