    const [open, setOpen] = useState<boolean>(false)
    const [openConfirm, setOpenConfirm] = useState<boolean>(false)
    const utils = api.useUtils()
    const itemForm = useForm<z.infer<typeof itemSchema>>({
        resolver: zodResolver(itemSchema),
