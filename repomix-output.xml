                    {dayjs(ticket.data?.eventTicket?.event.startsAt).locale('es').format('dddd D').charAt(0).toUpperCase()}{dayjs(ticket.data?.eventTicket?.event.startsAt).locale('es').format('dddd D').slice(1)} de {dayjs(ticket.data?.eventTicket?.event.startsAt).locale('es').format('MMMM').charAt(0).toUpperCase()}{dayjs(ticket.data?.eventTicket?.event.startsAt).locale('es').format('MMMM').slice(1)}, {ticket.data?.eventTicket?.event.startsAt ? dayjs(ticket.data?.eventTicket?.event.startsAt).locale('es').format('LT') : "00:00"}
                  </Text>
                </View>
                <Pressable style={{ position: 'absolute', right: 10, bottom: 15, padding: 6 }}>
                  <View style={{ flexDirection: 'row' }}>
